{
  "name": "external-note-folders",
  "version": "2.0.0",
  "description": "Associate Obsidian vault notes with lazily created folders under an external root using UUIDs, preserving stable associations across moves and reorganizations.",
  "license": "MIT",
  "author": "hollowhemlock",
  "type": "module",
  "scripts": {
    "build": "obsidian-dev-utils build",
    "build:clean": "obsidian-dev-utils build:clean",
    "dev": "obsidian-dev-utils dev",
    "docs:adr:index": "jiti scripts/update-adr-index.ts",
    "fixtures:new-sandbox": "jiti scripts/fixtures.ts --full && jiti scripts/reload-sandbox.ts && jiti scripts/check-obsidian-cli.ts",
    "vault:open": "jiti scripts/open-vault.ts",
    "format": "obsidian-dev-utils format",
    "format:check": "obsidian-dev-utils format:check",
    "lint": "obsidian-dev-utils lint",
    "lint:fix": "obsidian-dev-utils lint:fix",
    "spellcheck": "obsidian-dev-utils spellcheck",
    "test": "vitest run",
    "test:integration": "npm run integration:prepare && vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "jiti scripts/check-obsidian-cli.ts && vitest --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "release:check-assets": "jiti scripts/check-release-assets.ts",
    "release:check-versions": "jiti scripts/update-versions-json.ts --check",
    "release:update-versions": "jiti scripts/update-versions-json.ts",
    "integration:prepare": "jiti scripts/assert-primary-checkout.ts && npm run build && jiti scripts/fixtures.ts --full && jiti scripts/install-plugin-to-sandbox.ts && jiti scripts/reload-sandbox.ts && jiti scripts/check-obsidian-cli.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@codemirror/language": "latest",
    "@codemirror/state": "latest",
    "@codemirror/view": "latest",
    "@tsconfig/strictest": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "husky": "^9.1.7",
    "jiti": "latest",
    "obsidian": "latest",
    "obsidian-dev-utils": "latest",
    "obsidian-typings": "obsidian-public-latest",
    "react": "latest",
    "react-dom": "latest",
    "svelte": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "@antfu/utils": "9.2.0",
    "boolean": "npm:dry-uninstall",
    "dompurify": "3.0.1"
  }
}
